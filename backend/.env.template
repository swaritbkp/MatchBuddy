# ── System ──────────────────────
DEMO_MODE=true

# ── Gemini ──────────────────────
GEMINI_API_KEY=           # ← PASTE YOUR KEY HERE (Get from: https://aistudio.google.com/app/apikey)
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# ── Google Maps ─────────────────
GOOGLE_MAPS_API_KEY=      # ← PASTE YOUR KEY HERE (Get from: https://console.cloud.google.com → Enable: Maps JS API + Directions API)

# ── Firebase (Backend) ──────────
FIREBASE_DATABASE_URL=    # ← PASTE YOUR KEY HERE (Format: https://YOUR-PROJECT-ID-default-rtdb.firebaseio.com)
FIREBASE_STORAGE_BUCKET=  # ← PASTE YOUR KEY HERE (Format: YOUR-PROJECT-ID.appspot.com)
FIREBASE_FCM_SERVER_KEY=  # ← PASTE YOUR KEY HERE (Firebase Console → Project Settings → Cloud Messaging → Server key)
FIREBASE_SERVICE_ACCOUNT_JSON=  # ← PASTE YOUR KEY HERE (Firebase Console → Project Settings → Service Accounts → Generate new private key → paste entire JSON as single line)
